# ── Supabase ──────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Redis (Upstash — free at upstash.com) ────────────────────
# Get from: upstash.com → your database → REST URL (use rediss://)
REDIS_URL=rediss://default:yourpassword@your-instance.upstash.io:6379

# ── JWT ───────────────────────────────────────────────────────
# Any long random string — used to sign login tokens
JWT_SECRET=change-this-to-a-very-long-random-secret

# ── Server ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────
# Your Render service URL (set this after deploying)
# Leave empty in local dev
ALLOWED_ORIGIN=

# ── Admin credentials ─────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
# Generate with: node -e "import('bcryptjs').then(m=>m.default.hash('YourPassword',12).then(console.log))"
ADMIN_PASSWORD_HASH=
