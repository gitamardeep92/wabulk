# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Redis — use Upstash (free at upstash.com)
REDIS_URL=rediss://default:yourpassword@your-instance.upstash.io:6379

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Server
PORT=4000
NODE_ENV=development

# CORS — your Railway domain once deployed e.g. https://wabulk.up.railway.app
# Leave empty in dev, set on Railway dashboard for production
ALLOWED_ORIGIN=

# WA Session storage path
# On Railway this is a persistent volume mounted at /data
SESSION_PATH=./wa-sessions

# Admin credentials
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD_HASH=   # bcrypt hash — generate with: node -e "import('bcryptjs').then(m=>m.default.hash('yourpassword',12).then(console.log))"
