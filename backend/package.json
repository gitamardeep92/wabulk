{
  "name": "wabulk-backend",
  "version": "1.0.0",
  "description": "WaBulk API - WhatsApp Bulk Notification Service",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "worker": "node src/workers/messageWorker.js",
    "build:frontend": "cd ../frontend && npm install && npm run build && cp -r dist ../backend/public/app",
    "build:admin": "cd ../admin && npm install && npm run build && cp -r dist ../backend/public/admin",
    "build:marketing": "mkdir -p public/marketing && cp -r ../marketing/. public/marketing/",
    "build": "npm run build:frontend && npm run build:admin && npm run build:marketing",
    "railway-build": "npm install && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nanoid": "^5.0.4",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.0",
    "whatsapp-web.js": "^1.23.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
