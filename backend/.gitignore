# Dependencies - never commit these
node_modules/

# Environment files - contains secrets, never commit
.env
.env.local
.env.production

# Build output - generated on deploy
dist/
build/

# Backend generates this during build
backend/public/

# WhatsApp session files
.wwebjs_auth/
wa-sessions/

# Mac junk
.DS_Store
**/.DS_Store

# Logs
*.log
npm-debug.log*

# Editor folders
.vscode/
.idea/
